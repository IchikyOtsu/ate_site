generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Character {
  id               String   @id @default(uuid())
  discord_id       String   @unique
  discord_username String

  // Identité
  nom              String
  age              Int
  genre            String
  faction          String
  corporation      String
  grade            String

  // Descriptions
  description      String
  psychologie      String
  historique       String

  // Compétences (1-5)
  combat           Int
  survie           Int
  diplomatie       Int
  technique        Int

  status           String   @default("pending")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Champs bot Discord
  image_data        Bytes?
  avatar_message_id BigInt?
  avatar_channel_id BigInt?
  prefix            String?  @db.VarChar(20)

  @@map("characters")
}

// Rôles utilisateurs — partagé avec le bot
// role : "member" | "admin" | "moderator"
model UserRole {
  discord_id String   @id
  role       String   @default("member")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("user_roles")
}
